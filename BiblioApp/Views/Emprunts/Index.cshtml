@using Microsoft.AspNetCore.Identity
@model IEnumerable<BiblioApp.Models.Emprunt>

@{
    ViewData["Title"] = "Index";
}

<h1><i class="bi bi-clipboard"></i> Emprunts</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Bibliothecaire"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nouvel Emprunt</a>
    </p>
}
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.NomEmprunteur)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DateEmprunt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DateRetour)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Livre)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.NomEmprunteur)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateEmprunt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateRetour)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Livre.ISBN)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="bi bi-pencil"></i> Modifier</a>
                <span> </span>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info"><i class="bi bi-eye"></i> Détails</a>
                <span> </span>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Supprimer</a>
            </td>
        </tr>
}
    </tbody>
</table>
