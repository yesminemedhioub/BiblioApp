@using X.PagedList
@using X.PagedList.Mvc.Core
@using Microsoft.AspNetCore.Identity
@model X.PagedList.IPagedList<BiblioApp.Models.Emprunt>

@{
    ViewData["Title"] = "Emprunts en cours";
}

<h2><i class="bi bi-clipboard"></i> Emprunts en cours</h2>

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control" placeholder="Rechercher par emprunteur ou titre du livre..." />
            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle"></i>
                </a>
            }
        </form>
    </div>
    <div class="col-md-6 text-end">
        @if (User.IsInRole("Admin") || User.IsInRole("Bibliothecaire"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nouvel Emprunt
            </a>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(ViewBag.Search as string))
{
    <div class="alert alert-info">
        🔍 Résultats pour : <strong>@ViewBag.Search</strong>
        — @Model.TotalItemCount résultat(s) trouvé(s)
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">📭 Aucun emprunt en cours.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Emprunteur</th>
                <th>Livre</th>
                <th>Auteur du livre</th>
                <th>Date d'emprunt</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.NomEmprunteur</td>
                    <td>@item.Livre?.Titre</td>
                    <td>@item.Livre?.Auteur?.NomComplet</td>
                    <td>@item.DateEmprunt.ToShortDateString()</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn btn-sm btn-info">
                            <i class="bi bi-eye"></i>
                        </a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Bibliothecaire"))
                        {
                            <form asp-action="Retourner" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-success">
                                    <i class="bi bi-check-circle"></i> Retourner
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <span class="text-muted">
            Page @Model.PageNumber sur @Model.PageCount
            — @Model.TotalItemCount élément(s) au total
        </span>
        @Html.PagedListPager(Model, page => Url.Action("Index",
        new { page, search = ViewBag.Search }),
        new X.PagedList.Mvc.Core.PagedListRenderOptions
        {
            LiElementClasses = new[] { "page-item" },
            PageClasses = new[] { "page-link" },
            UlElementClasses = new[] { "pagination" }
        })
</div>
}