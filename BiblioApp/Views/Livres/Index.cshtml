@using X.PagedList
@using X.PagedList.Mvc.Core
@using Microsoft.AspNetCore.Identity
@model X.PagedList.IPagedList<BiblioApp.Models.Livre>

@{
    ViewData["Title"] = "Liste des Livres";
}

<h2><i class="bi bi-book"></i> Liste des Livres</h2>

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control" placeholder="Rechercher par titre, ISBN, auteur..." />
            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle"></i>
                </a>
            }
        </form>
    </div>
    <div class="col-md-6 text-end">
        @if (User.IsInRole("Admin") || User.IsInRole("Bibliothecaire"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nouveau Livre
            </a>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(ViewBag.Search as string))
{
    <div class="alert alert-info">
        🔍 Résultats pour : <strong>@ViewBag.Search</strong>
        — @Model.TotalItemCount résultat(s) trouvé(s)
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-warning">📭 Aucun livre trouvé.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Titre</th>
                <th>ISBN</th>
                <th>Année</th>
                <th>Auteur</th>
                <th>Disponibilité</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Titre</td>
                    <td>@item.ISBN</td>
                    <td>@item.AnneePublication</td>
                    <td>@item.Auteur?.NomComplet</td>
                    <td>
                        @if (item.EstDisponible)
                        {
                            <span class="badge bg-success">✅ Disponible</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">❌ Emprunté</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn btn-sm btn-info">
                            <i class="bi bi-eye"></i>
                        </a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Bibliothecaire"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @* Pagination *@
    <div class="d-flex justify-content-between align-items-center mt-3">
        <span class="text-muted">
            Page @Model.PageNumber sur @Model.PageCount
            — @Model.TotalItemCount élément(s) au total
        </span>
        @Html.PagedListPager(Model, page => Url.Action("Index",
        new { page, search = ViewBag.Search }),
        new X.PagedList.Mvc.Core.PagedListRenderOptions
        {
            LiElementClasses = new[] { "page-item" },
            PageClasses = new[] { "page-link" },
            UlElementClasses = new[] { "pagination" }
        })
</div>
}