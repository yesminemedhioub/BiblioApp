@model BiblioApp.Models.Auteur

@{
    ViewData["Title"] = "Supprimer un Auteur";
}

<h2>🗑️ Supprimer un Auteur</h2>

<div class="alert alert-danger">
    ⚠️ Attention ! Cette action est irréversible.
</div>

<div class="card col-md-6">
    <div class="card-body">

        <h5 class="card-title">Confirmez-vous la suppression de cet auteur ?</h5>
        <hr />

        <dl class="row">
            <dt class="col-sm-4">Nom complet</dt>
            <dd class="col-sm-8">@Model.NomComplet</dd>

            <dt class="col-sm-4">Date de naissance</dt>
            <dd class="col-sm-8">@Model.DateNaissance.ToShortDateString()</dd>

            <dt class="col-sm-4">Nombre de livres</dt>
            <dd class="col-sm-8">
                @if (Model.Livres.Count > 0)
                {
                    <span class="badge bg-warning text-dark">
                         @Model.Livres.Count livre(s) associé(s)
                    </span>
                }
                else
                {
                    <span class="badge bg-success">Aucun livre</span>
                }
            </dd>
        </dl>

        @* Formulaire de confirmation de suppression *@
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()

            @* L'Id est envoyé via la route, pas besoin de hidden field ici *@
            <input type="hidden" asp-for="Id" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                     Oui, supprimer
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                     Annuler
                </a>
            </div>
        </form>

    </div>
</div>