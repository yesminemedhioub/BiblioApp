@model BiblioApp.Models.Auteur

@{
    ViewData["Title"] = "Modifier un Auteur";
}

<h2>✏️ Modifier l'Auteur</h2>

<div class="row">
    <div class="col-md-6">

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            @* Champ caché pour envoyer l'Id au contrôleur *@
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Nom" class="form-label"></label>
                <input asp-for="Nom" class="form-control" />
                <span asp-validation-for="Nom" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Prenom" class="form-label"></label>
                <input asp-for="Prenom" class="form-control" />
                <span asp-validation-for="Prenom" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DateNaissance" class="form-label"></label>
                <input asp-for="DateNaissance" type="date" class="form-control" />
                <span asp-validation-for="DateNaissance" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Enregistrer</button>
                <a asp-action="Index" class="btn btn-secondary">Annuler</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}