@model BiblioApp.Models.Emprunt

@{
    ViewData["Title"] = "Nouvel Emprunt";
}

<h2> Enregistrer un Emprunt</h2>

<div class="row">
    <div class="col-md-6">

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            @* Nom de l'emprunteur *@
            <div class="mb-3">
                <label asp-for="NomEmprunteur" class="form-label"></label>
                <input asp-for="NomEmprunteur" class="form-control"
                       placeholder="Ex: Ahmed Ben Ali" />
                <span asp-validation-for="NomEmprunteur" class="text-danger"></span>
            </div>

            @* Liste des livres disponibles *@
            <div class="mb-3">
                <label asp-for="LivreId" class="form-label">Livre</label>
                <select asp-for="LivreId" asp-items="ViewBag.Livres" class="form-select">
                    <option value="">-- Choisir un livre disponible --</option>
                </select>
                <span asp-validation-for="LivreId" class="text-danger"></span>
            </div>

            @* Date d'emprunt — pré-remplie avec aujourd'hui *@
            <div class="mb-3">
                <label asp-for="DateEmprunt" class="form-label"></label>
                <input asp-for="DateEmprunt" type="date" class="form-control"
                       value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="DateEmprunt" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Enregistrer</button>
                <a asp-action="Index" class="btn btn-secondary">Annuler</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}