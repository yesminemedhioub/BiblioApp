@model IEnumerable<BiblioApp.Models.Emprunt>

@{
    ViewData["Title"] = "Emprunts en cours";
}

<h2>Emprunts en cours</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Nouvel Emprunt</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Aucun emprunt en cours actuellement.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Emprunteur</th>
                <th>Livre</th>
                <th>Auteur du livre</th>
                <th>Date d'emprunt</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emprunt in Model)
            {
                <tr>
                    <td>@emprunt.NomEmprunteur</td>
                    <td>@emprunt.Livre?.Titre</td>
                    <td>@emprunt.Livre?.Auteur?.NomComplet</td>
                    <td>@emprunt.DateEmprunt.ToShortDateString()</td>
                    <td>
                        @* Formulaire inline pour marquer comme retourné *@
                        <form asp-action="Retourner" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@emprunt.Id" />
                            <button type="submit" class="btn btn-sm btn-success">
                                Marquer retourné
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}